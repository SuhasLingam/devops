<!DOCTYPE html>
<html>
<body>

<h2>Message App</h2>

<input id="msg" placeholder="Enter message" />
<button onclick="send()">Send</button>

<ul id="list"></ul>

<script>
const API = "http://<BACKEND-IP>:8080";

async function send() {
  let text = document.getElementById("msg").value;

  await fetch(API + "/add", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ text })
  });

  load();
}

async function load() {
  let res = await fetch(API + "/get");
  let data = await res.json();

  let list = document.getElementById("list");
  list.innerHTML = "";

  data.forEach(m => {
    let li = document.createElement("li");
    li.innerText = m.text;
    list.appendChild(li);
  });
}

load();
</script>

</body>
</html>